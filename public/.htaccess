Options -Indexes
RewriteEngine On

# Si es un archivo físico, serve directamente
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Si es un directorio físico, serve directamente
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Todo lo demás → index.php (el router principal)
RewriteRule ^(.*)$ index.php [L,QSA]
